---
import BaseLayout from './BaseLayout.astro';
import Utterances from '../components/Utterances.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  wordCount?: number;
}

const { post, wordCount } = Astro.props;
const { title, description, date, updated, tags, cover } = post.data;

const dateIso = date.toISOString();
const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedIso = updated?.toISOString();
const readingMinutes = wordCount ? Math.max(1, Math.round(wordCount / 220)) : undefined;
---

<BaseLayout
  title={title}
  description={description}
  image={cover ?? '/og-default.png'}
  article={{
    publishedTime: dateIso,
    modifiedTime: updatedIso,
    tags,
    wordCount,
  }}
>
  <ReadingProgress />
  <article class="post">
    <header class="post-header">
      <p class="meta">
        <time datetime={dateIso}>{dateLabel}</time>
        {readingMinutes && (
          <>
            <span class="dot" aria-hidden="true">·</span>
            <span>{readingMinutes} min read</span>
          </>
        )}
      </p>
      <h1>{title}</h1>
      {description && <p class="lede">{description}</p>}
      {tags.length > 0 && (
        <ul class="tags">
          {tags.map((t) => (
            <li><a href={`/blog/tags/${t}/`}>#{t}</a></li>
          ))}
        </ul>
      )}
    </header>

    <aside class="ai-free" aria-label="Authorship notice">
      <span class="ai-free-label">Human-written</span>
      <p>This article was written by a human, without the use of generative AI.</p>
    </aside>

    <div class="prose post-body">
      <slot />
    </div>

    <Utterances />
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 68ch;
    margin: 3rem auto 2rem;
    padding: 0 1.25rem;
  }
  .post-header {
    margin-bottom: 2.5rem;
  }
  .meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
  }
  .post-header h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(2.2rem, 1.4rem + 3vw, 3.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    font-variation-settings: 'opsz' 144;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--color-fg-muted);
    line-height: 1.55;
    margin: 0 0 1rem;
    text-wrap: balance;
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .tags a {
    color: var(--color-fg-subtle);
    text-decoration: none;
  }
  .tags a:hover { color: var(--color-accent); }

  .ai-free {
    margin: 0 0 2.5rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    border-radius: 4px;
    background: var(--color-bg-elev);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.75rem;
  }
  .ai-free-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .ai-free p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-fg-muted);
    line-height: 1.5;
  }
</style>
