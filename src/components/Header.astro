---
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts.ts';

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="inner">
    <a href="/" class="brand" rel="home">
      <span class="brand-mark" aria-hidden="true">L</span>
      <span class="brand-name">{SITE_TITLE}</span>
    </a>
    <nav aria-label="Primary">
      <a href="/" class:list={[isActive('/') && 'active']}>About</a>
      <a href="/blog/" class:list={[isActive('/blog') && 'active']}>Blog</a>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background-color: color-mix(in oklab, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .inner {
    max-width: 72ch;
    margin: 0 auto;
    padding: 0.875rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-fg);
    text-decoration: none;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    margin-right: auto;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    border-radius: 0.4rem;
    background-color: var(--color-accent);
    color: var(--color-accent-fg);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1;
  }
  nav {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
  }
  nav a {
    color: var(--color-fg-muted);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition: color 150ms ease, border-color 150ms ease;
  }
  nav a:hover { color: var(--color-fg); }
  nav a.active {
    color: var(--color-fg);
    border-bottom-color: var(--color-accent);
  }
  @media (max-width: 480px) {
    .brand-name { display: none; }
  }
</style>
